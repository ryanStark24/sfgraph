<?xml version="1.0" encoding="UTF-8"?>
<Flow xmlns="http://soap.sforce.com/2006/04/metadata">
    <apiVersion>60.0</apiVersion>
    <label>Simple Account Update</label>
    <processType>AutoLaunchedFlow</processType>
    <status>Active</status>
    <start>
        <locationX>50</locationX>
        <locationY>0</locationY>
        <object>Account</object>
        <recordTriggerType>Update</recordTriggerType>
        <triggerType>RecordBeforeSave</triggerType>
    </start>
    <recordUpdates>
        <name>Update_Account_Status</name>
        <label>Update Account Status</label>
        <locationX>176</locationX>
        <locationY>134</locationY>
        <inputAssignments>
            <field>Status__c</field>
            <value>
                <stringValue>Active</stringValue>
            </value>
        </inputAssignments>
        <inputReference>$Record</inputReference>
    </recordUpdates>
    <actionCalls>
        <name>Call_Apex_Action</name>
        <label>Call Apex Action</label>
        <locationX>176</locationX>
        <locationY>278</locationY>
        <actionName>AccountService</actionName>
        <actionType>apex</actionType>
    </actionCalls>
    <subflows>
        <name>Run_Child_Flow</name>
        <label>Run Child Flow</label>
        <locationX>176</locationX>
        <locationY>422</locationY>
        <flowName>Child_Account_Validation</flowName>
    </subflows>
    <textTemplates>
        <name>Status_Label</name>
        <text>Status is {!$Label.Account_Status_Label}</text>
    </textTemplates>
    <decisions>
        <name>Check_Status</name>
        <label>Check Status</label>
        <locationX>176</locationX>
        <locationY>566</locationY>
        <defaultConnectorLabel>Default Outcome</defaultConnectorLabel>
        <rules>
            <name>Is_Active</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>$Record.Status__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>Active</stringValue>
                </rightValue>
            </conditions>
            <label>Is Active</label>
        </rules>
    </decisions>
</Flow>
