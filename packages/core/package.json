{
  "name": "@sfgraph/core",
  "version": "1.0.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./domain": {
      "types": "./dist/domain/index.d.ts",
      "default": "./dist/domain/index.js"
    },
    "./telemetry": {
      "types": "./dist/telemetry/index.d.ts",
      "default": "./dist/telemetry/index.js"
    },
    "./extractors/live-org": {
      "types": "./dist/extractors/live-org/index.d.ts",
      "default": "./dist/extractors/live-org/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json && node --input-type=module -e \"import {cpSync, mkdirSync} from 'node:fs'; mkdirSync('dist/extractors/live-org/vlocity',{recursive:true}); cpSync('src/extractors/live-org/vlocity/query-definitions.yml','dist/extractors/live-org/vlocity/query-definitions.yml');\"",
    "test": "vitest run",
    "lint": "biome check src",
    "lint:fix": "biome check --write src",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@babel/parser": "^7.29.3",
    "@babel/traverse": "^7.29.0",
    "@babel/types": "^7.29.0",
    "@salesforce/core": "^8.30.0",
    "@sfgraph/shared": "workspace:*",
    "apex-parser": "^2.17.0",
    "better-sqlite3": "^12.10.0",
    "bottleneck": "^2.19.5",
    "fast-xml-parser": "^5.8.0",
    "jsforce": "^3.10.14",
    "p-limit": "^7.3.0",
    "parse5": "^8.0.1",
    "piscina": "^5.1.4",
    "sqlite-vec": "^0.1.9",
    "yaml": "^2.9.0",
    "zod": "^3.25.76",
    "zod-to-json-schema": "^3.25.2"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.0",
    "@types/babel__traverse": "^7.28.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/jsforce": "^1.11.6",
    "@types/node": "^22.0.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/ryanStark24/sfgraph"
  },
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "access": "public"
  },
  "description": "sfgraph engine: storage, parsers, extractors, analyze, render",
  "files": [
    "dist",
    "README.md"
  ],
  "keywords": [
    "salesforce",
    "sfgraph",
    "mcp",
    "graph",
    "apex",
    "lwc",
    "flow"
  ]
}
