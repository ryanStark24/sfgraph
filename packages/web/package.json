{
  "name": "@ryanstark24/sfgraph-web",
  "version": "1.1.5",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json && node --input-type=module -e \"import {cpSync,mkdirSync} from 'node:fs'; mkdirSync('dist/public',{recursive:true}); cpSync('public','dist/public',{recursive:true});\"",
    "test": "vitest run --passWithNoTests",
    "lint": "biome check src",
    "lint:fix": "biome check --write src",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@ryanstark24/sfgraph-core": "workspace:*",
    "@ryanstark24/sfgraph-shared": "workspace:*"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.0",
    "@types/node": "^22.0.0",
    "typescript": "^5.6.0",
    "vitest": "^3.2.4"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/ryanStark24/sfgraph"
  },
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "access": "public"
  },
  "description": "sfgraph local web visualiser — graph explorer for ingested orgs",
  "files": [
    "dist",
    "README.md"
  ]
}
