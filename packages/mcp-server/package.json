{
  "name": "@ryanstark24/sfgraph-server",
  "version": "1.1.4",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "vitest run",
    "lint": "biome check src",
    "lint:fix": "biome check --write src",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "zod": "^3.25.76",
    "zod-to-json-schema": "^3.25.2",
    "@ryanstark24/sfgraph-core": "workspace:*",
    "@ryanstark24/sfgraph-shared": "workspace:*",
    "@salesforce/core": "^8.30.0",
    "better-sqlite3": "^12.10.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.0",
    "@types/node": "^22.0.0",
    "typescript": "^5.6.0",
    "vitest": "^3.2.4"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/ryanStark24/sfgraph"
  },
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "access": "public"
  },
  "description": "sfgraph MCP server: 19 tools over stdio",
  "files": [
    "dist",
    "README.md"
  ],
  "keywords": [
    "salesforce",
    "sfgraph",
    "mcp",
    "graph",
    "apex",
    "lwc",
    "flow"
  ]
}
