{
  "name": "@ryanstark24/sfgraph",
  "version": "1.1.8",
  "type": "module",
  "bin": {
    "sfgraph": "./bin/sfgraph.mjs"
  },
  "files": [
    "bin",
    "scripts",
    "README.md"
  ],
  "scripts": {
    "postinstall": "node ./scripts/verify-native.mjs || true",
    "prepack": "node -e \"require('node:fs').copyFileSync('../../README.md','./README.md')\"",
    "postpack": "node -e \"require('node:fs').rmSync('./README.md',{force:true})\"",
    "build": "echo no-op",
    "test": "vitest run --passWithNoTests",
    "lint": "biome check bin",
    "lint:fix": "biome check --write bin",
    "typecheck": "echo no-op",
    "clean": "echo no-op"
  },
  "dependencies": {
    "@ryanstark24/sfgraph-cli": "workspace:*",
    "@ryanstark24/sfgraph-server": "workspace:*"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.0",
    "vitest": "^3.2.4"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/ryanStark24/sfgraph"
  },
  "engines": {
    "node": ">=20"
  },
  "description": "Local, privacy-first Salesforce org knowledge graph for MCP clients (Cursor, Claude, VS Code)",
  "keywords": [
    "salesforce",
    "sfgraph",
    "mcp",
    "cursor",
    "claude",
    "code-analysis",
    "apex",
    "lwc"
  ],
  "publishConfig": {
    "access": "public"
  }
}
